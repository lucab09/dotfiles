PLUGIN_DIR="$CONFIG_DIR/plugins"

##### Bar #####
sketchybar --bar position=top \
               height=36 \
               blur_radius=0 \
               color=0x00000000 \
               border_width=0 \
               shadow=off \
               margin=8 \
               padding_left=0 \
               padding_right=0 \
               y_offset=8 \
               topmost=window

##### Defaults #####
sketchybar --default \
  padding_left=4 \
  padding_right=4 \
  icon.font="JetBrainsMono Nerd Font:Bold:15.0" \
  label.font="Google Sans Flex 18pt:Semibold:15.0" \
  icon.color=0xffcdd6f4 \
  label.color=0xffcdd6f4 \
  icon.padding_left=8 \
  icon.padding_right=4 \
  label.padding_left=0 \
  label.padding_right=8 \
  background.drawing=on \
  background.color=0xff313244 \
  background.corner_radius=14 \
  background.height=28

##### LEFT #####

# Orario — primo elemento della barra
sketchybar --add item clock_time left \
           --set clock_time \
             update_freq=30 \
             icon.drawing=off \
             label.font="Google Sans Flex 18pt:Medium:16.0" \
             label.color=0xffe6e1e5 \
             label.padding_left=12 \
             label.padding_right=12 \
             background.drawing=on \
             background.color=0xff49454f \
             background.corner_radius=16 \
             background.height=34 \
             script="$PLUGIN_DIR/clock_time.sh"

# Data — subito dopo l'orologio
sketchybar --add item clock_date left \
           --set clock_date \
             update_freq=60 \
             icon.drawing=off \
             label.font="Google Sans Flex 18pt:Medium:14.0" \
             label.color=0xffcac4d0 \
             label.padding_left=12 \
             label.padding_right=12 \
             background.drawing=on \
             background.color=0xff49454f \
             background.corner_radius=16 \
             background.height=34 \
             script="$PLUGIN_DIR/clock_date.sh"

# Meteo — subito dopo la data
sketchybar --add item weather left \
           --set weather \
             update_freq=900 \
             icon.font="Material Symbols Rounded:Regular:14.0" \
             icon.color=0xffcac4d0 \
             icon.padding_left=12 \
             icon.padding_right=4 \
             label.font="Google Sans Flex 18pt:Medium:14.0" \
             label.color=0xffe6e1e5 \
             label.padding_left=0 \
             label.padding_right=12 \
             background.drawing=on \
             background.color=0xff49454f \
             background.corner_radius=16 \
             background.height=34 \
             script="$PLUGIN_DIR/weather.sh" \
             click_script="$PLUGIN_DIR/weather_set_location.sh"

##### CENTER #####

# Sui Mac con notch fisico il widget calendario vive già nel notch stesso
# (overlay disegnato da calendar_notch); qui aggiungiamo un item nativo solo
# dove non c'è un notch, così eredita la fissità della barra vera invece di
# scorrere durante lo swipe tra scrivanie.
HAS_NOTCH=$("$PLUGIN_DIR/has_notch" 2>/dev/null)
if [ "$HAS_NOTCH" != "1" ]; then
  sketchybar --add item calendar_center center \
             --set calendar_center \
               update_freq=20 \
               icon="●" \
               icon.font="Google Sans Flex 18pt:Regular:14.0" \
               icon.color=0x44cdd6f4 \
               icon.padding_left=12 \
               icon.padding_right=6 \
               label.font="Google Sans Flex 18pt:Medium:14.0" \
               label.color=0xffe6e1e5 \
               label.padding_left=0 \
               label.padding_right=12 \
               background.drawing=on \
               background.color=0xff49454f \
               background.corner_radius=16 \
               background.height=34 \
               script="$PLUGIN_DIR/calendar.sh" \
             --subscribe calendar_center mouse.entered mouse.exited
fi

##### RIGHT #####
