           --set right_pill \
             background.drawing=on \
             background.color=0xff49454f \
             background.corner_radius=16 \
             background.height=34

sketchybar --update

# Avvia/riavvia network popup
if [ -f /tmp/network_popup.pid ]; then
  kill "$(cat /tmp/network_popup.pid)" 2>/dev/null
fi
"$PLUGIN_DIR/network_popup" &
echo $! > /tmp/network_popup.pid

# Avvia il widget calendario: usa il notch fisico se presente, altrimenti
# disegna un pill centrato alla stessa altezza della bar (gestito internamente
# dal binario in base alla geometria dello schermo).
CALENDAR_NOTCH_PID=/tmp/calendar_notch.pid
if [ -f "$CALENDAR_NOTCH_PID" ]; then
  kill "$(cat "$CALENDAR_NOTCH_PID")" 2>/dev/null
  rm -f "$CALENDAR_NOTCH_PID"
fi

if [ -x "$PLUGIN_DIR/calendar_notch" ]; then
  "$PLUGIN_DIR/calendar_notch" &
  echo $! > "$CALENDAR_NOTCH_PID"
fi
